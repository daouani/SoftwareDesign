def compare1(x,y,):
    if x > y:
        z = 1
        return z
    elif x == y:
        z = 0
        return z
    else:
        z = -1
        return z
        z = 1

a = raw_input (" input 1st number :")
b = raw_input (" input 2nd number :")
a = int(a)
b = int(b)
x = compare1(a,b,)

print x
